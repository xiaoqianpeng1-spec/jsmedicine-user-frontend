{"file":"default-AA8FgiVH.js","mappings":";;;;;;;;;;;;;;;;;;;;;AAyEA,UAAM,QAAQ,SAAA;AACC,cAAA;AACf,UAAM,YAAY,aAAA;AAClB,UAAM,EAAE,SAAA,IAAa,YAAY,SAAS;AAE1C,UAAM,cAAc;AAAA,MAClB,EAAE,MAAM,SAAS,OAAO,KAAA;AAAA,MACxB,EAAE,MAAM,aAAa,OAAO,KAAA;AAAA,MAC5B,EAAE,MAAM,WAAW,OAAO,KAAA;AAAA,MAC1B,EAAE,MAAM,UAAU,OAAO,KAAA;AAAA,MACzB,EAAE,MAAM,UAAU,OAAO,KAAA;AAAA,MACzB,EAAE,MAAM,UAAU,OAAO,KAAA;AAAA,MACzB,EAAE,MAAM,YAAY,OAAO,KAAA;AAAA,MAC3B,EAAE,MAAM,SAAS,OAAO,KAAA;AAAA,IAAK;AAI/B,UAAM,aAAa,SAAS,MAAM;AAChC,aAAO,SAAS,MAAM,UAAU;AAAA,IAClC,CAAC;AAED,UAAM,WAAW,SAAS,MAAM;AAC9B,aAAO,SAAS,MAAM,YAAY,SAAS,MAAM,YAAY;AAAA,IAC/D,CAAC;AAEkB,aAAS,MAAM;AAChC,aAAO,CAAC,CAAC,GAAG,EAAE,SAAS,MAAM,IAAI;AAAA,IACnC,CAAC;AAED,UAAM,WAAW,CAAC,SAAiB;AACjC,aAAO,MAAM,SAAS;AAAA,IACxB;;;mBAvGOA,eAAAC,WAAA,EAAA,OAAM,aAAA,GAAY,MAAA,CAAA,4JAIVC,cAAA,OAAA,UAAe;AAMHC,oBAAA,cAAR,SAAI;;UACV,KAAK,KAAK;AAAA,UACV,IAAI,KAAK;AAAA,UACV,QAAM,YAAU,EAAA,QACE,SAAS,KAAK,IAAI,EAAA,CAAA;AAAA,QAAA;2BALtC,CAQc,GAAAC,QAAAC,UAAA,aAAA;;AADTD,qBAAA,GAAAE,eAAA,KAAK,KAAK,CAAA,EAAA;AAAA;;gBAAVC,gBAAAC,gBAAA,KAAK,KAAK,GAAA,CAAA;AAAA,cAAA;AAAA;;;;;;;QAKF,IAAG;AAAA,QAAW,OAAM;AAAA,MAAA;yBAAjC,CAOc,GAAAJ,QAAAC,UAAA,aAAA;;0BALTH,cAAA,OAAK,WAAA,KAAU,iIAIS,SAAA,KAAQ;;;cALnCO,YAIE,OAAA;AAAA,gBAHC,KAAK,WAAA;AAAA,gBACN,KAAI;AAAA,gBACJ,OAAM;AAAA,cAAA;cAERA,YAA6C,QAAA,EAAvC,OAAM,YAAA,mBAAe,SAAA,KAAQ,GAAA,CAAA;AAAA,YAAA;AAAA;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderAttr","_ssrRenderList","_push","_parent","_ssrInterpolate","_createTextVNode","_toDisplayString","_createVNode"],"sources":["../../../../layouts/default.vue"],"sourcesContent":["<template>\r\n  <div class=\"app-layout\">\r\n    <header class=\"app-header\">\r\n      <div class=\"header-container\">\r\n        <div class=\"logo-section\" @click=\"router.push('/home')\">\r\n          <img src=\"/icon.png\" alt=\"江苏省中医药管理局\" class=\"logo-image\" />\r\n          <span class=\"logo-text\">中医在线</span>\r\n        </div>\r\n        \r\n        <nav class=\"header-nav\">\r\n          <router-link \r\n            v-for=\"item in topNavItems\" \r\n            :key=\"item.path\"\r\n            :to=\"item.path\"\r\n            class=\"nav-link\"\r\n            :class=\"{ active: isActive(item.path) }\"\r\n          >\r\n            {{ item.label }}\r\n          </router-link>\r\n        </nav>\r\n        \r\n        <div class=\"header-right\">\r\n          <router-link to=\"/profile\" class=\"user-link\">\r\n            <img \r\n              :src=\"userAvatar\" \r\n              alt=\"用户头像\" \r\n              class=\"user-avatar\"\r\n            />\r\n            <span class=\"user-name\">{{ userName }}</span>\r\n          </router-link>\r\n        </div>\r\n      </div>\r\n    </header>\r\n    \r\n    <main class=\"app-main\">\r\n      <slot />\r\n    </main>\r\n    \r\n    <footer class=\"footer\">\r\n      <div class=\"footer-container\">\r\n        <div class=\"footer-content\">\r\n          <div class=\"footer-info\">\r\n            <h4>联系我们</h4>\r\n            <p>微信公众号: wz123545</p>\r\n            <p>QQ: 1235345</p>\r\n            <p>QQ: 1235345</p>\r\n            <p>Email: 1235345@163.com</p>\r\n          </div>\r\n          <div class=\"footer-qrcodes\">\r\n            <div class=\"qrcode-item\">\r\n              <img src=\"https://neeko-copilot.bytedance.net/api/text_to_image?prompt=QR%20code%20simple%20black%20white&image_size=square_hd\" alt=\"关注公众号\" />\r\n              <span>关注公众号</span>\r\n            </div>\r\n            <div class=\"qrcode-item\">\r\n              <img src=\"https://neeko-copilot.bytedance.net/api/text_to_image?prompt=QR%20code%20simple%20black%20white&image_size=square_hd\" alt=\"小程序\" />\r\n              <span>江苏中医在线小程序</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"footer-copyright\">\r\n          <p>Copyright@2013********苏ICP备12345678号</p>\r\n        </div>\r\n      </div>\r\n    </footer>\r\n  </div>\r\n</template>\r\n\r\n<script setup lang=\"ts\">\r\nimport { computed } from 'vue'\r\nimport { useRoute, useRouter } from 'vue-router'\r\nimport { useUserStore } from '~/stores/user'\r\nimport { storeToRefs } from 'pinia'\r\n\r\nconst route = useRoute()\r\nconst router = useRouter()\r\nconst userStore = useUserStore()\r\nconst { userInfo } = storeToRefs(userStore)\r\n\r\nconst topNavItems = [\r\n  { path: '/home', label: '首页' },\r\n  { path: '/articles', label: '资讯' },\r\n  { path: '/topics', label: '专题' },\r\n  { path: '/video', label: '视频' },\r\n  { path: '/audio', label: '音频' },\r\n  { path: '/books', label: '图书' },\r\n  { path: '/consult', label: '咨询' },\r\n  { path: '/exam', label: '考核' }\r\n]\r\n\r\n// 从用户store获取头像和用户名\r\nconst userAvatar = computed(() => {\r\n  return userInfo.value.avatar || 'https://neeko-copilot.bytedance.net/api/text_to_image?prompt=cute%20cat%20avatar%20portrait%20simple&image_size=square'\r\n})\r\n\r\nconst userName = computed(() => {\r\n  return userInfo.value.nickname || userInfo.value.username || '用户'\r\n})\r\n\r\nconst showTopNav = computed(() => {\r\n  return !['/'].includes(route.path)\r\n})\r\n\r\nconst isActive = (path: string) => {\r\n  return route.path === path\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.app-layout {\r\n  min-height: 100vh;\r\n  display: flex;\r\n  flex-direction: column;\r\n  background-color: #f5f5f5;\r\n}\r\n\r\n.app-header {\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 100;\r\n  background: #fff;\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);\r\n}\r\n\r\n.header-container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 0 20px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  height: 60px;\r\n}\r\n\r\n.logo-section {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n}\r\n\r\n.logo-image {\r\n  width: 32px;\r\n  height: 32px;\r\n  object-fit: contain;\r\n}\r\n\r\n.logo-text {\r\n  font-size: 18px;\r\n  font-weight: 700;\r\n  color: #2D5A27;\r\n}\r\n\r\n.header-nav {\r\n  display: flex;\r\n  gap: 32px;\r\n}\r\n\r\n.nav-link {\r\n  text-decoration: none;\r\n  font-size: 14px;\r\n  color: #666;\r\n  font-weight: 500;\r\n  transition: color 0.3s;\r\n}\r\n\r\n.nav-link:hover,\r\n.nav-link.active {\r\n  color: #4CAF50;\r\n}\r\n\r\n.header-right {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.user-link {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  text-decoration: none;\r\n}\r\n\r\n.user-avatar {\r\n  width: 36px;\r\n  height: 36px;\r\n  border-radius: 50%;\r\n  object-fit: cover;\r\n}\r\n\r\n.user-name {\r\n  font-size: 14px;\r\n  color: #333;\r\n  font-weight: 500;\r\n}\r\n\r\n.app-main {\r\n  flex: 1;\r\n}\r\n\r\n.footer {\r\n  background: #333;\r\n  padding: 40px 0;\r\n}\r\n\r\n.footer-container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 0 20px;\r\n}\r\n\r\n.footer-content {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: flex-start;\r\n  padding-bottom: 30px;\r\n  border-bottom: 1px solid #444;\r\n}\r\n\r\n.footer-info h4 {\r\n  color: #fff;\r\n  font-size: 18px;\r\n  margin: 0 0 16px 0;\r\n}\r\n\r\n.footer-info p {\r\n  color: #999;\r\n  font-size: 14px;\r\n  margin: 8px 0;\r\n}\r\n\r\n.footer-qrcodes {\r\n  display: flex;\r\n  gap: 40px;\r\n}\r\n\r\n.qrcode-item {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n}\r\n\r\n.qrcode-item img {\r\n  width: 100px;\r\n  height: 100px;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.qrcode-item span {\r\n  color: #999;\r\n  font-size: 12px;\r\n}\r\n\r\n.footer-copyright {\r\n  text-align: center;\r\n  padding-top: 20px;\r\n}\r\n\r\n.footer-copyright p {\r\n  color: #666;\r\n  font-size: 13px;\r\n  margin: 0;\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .header-nav {\r\n    display: none;\r\n  }\r\n  \r\n  .footer-content {\r\n    flex-direction: column;\r\n    align-items: center;\r\n    gap: 30px;\r\n  }\r\n}\r\n</style>"],"version":3}