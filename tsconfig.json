{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "~/*": ["./*"]
    },
    "types": ["@types/node"],
    "typeRoots": ["./node_modules/@types", "./.nuxt/types"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "pages/**/*.vue", "composables/**/*.ts", "stores/**/*.ts", ".nuxt/**/*.d.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
